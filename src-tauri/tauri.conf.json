{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oaki Studio Widget",
  "version": "0.1.0",
  "identifier": "studio.oaki.widget",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:3000/app/widget"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Oaki Studio production tracking widget",
    "longDescription": "Desktop widget for the Oaki Studio internal production tracking app."
  }
}
